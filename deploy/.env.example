DISCWEAVE_POSTGRES_PASSWORD=change-this-local-secret
DISCWEAVE_HOST_PORT=8080
DISCWEAVE_DISCOGS_ENABLED=false
DISCWEAVE_DISCOGS_BASE_URL=https://api.discogs.com
