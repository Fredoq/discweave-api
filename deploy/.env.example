CRATEBASE_POSTGRES_PASSWORD=change-this-local-secret
CRATEBASE_HOST_PORT=8080
CRATEBASE_DISCOGS_ENABLED=false
CRATEBASE_DISCOGS_BASE_URL=https://api.discogs.com
CRATEBASE_DISCOGS_USER_AGENT="Cratebase/0.1 (+https://cratebase.example.com)"
CRATEBASE_DISCOGS_TIMEOUT_SECONDS=10

# Do not put Discogs__AccessToken in this file. Store the token in the hosted
# secret manager or an untracked local developer secret store.
